generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_PRISMA_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

// Auth Models (NextAuth.js)
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  role          UserRole  @default(USER)
  accounts      Account[]
  sessions      Session[]

  submittedParks   Park[]           @relation("SubmittedParks")
  favorites        UserFavorite[]
  uploadedPhotos   ParkPhoto[]
  reviews          ParkReview[]
  helpfulVotes     ReviewHelpfulVote[]
  trailConditions  TrailCondition[]
  operatorUsers    OperatorUser[]
  parkClaims       ParkClaim[]
  parkEditLogs     ParkEditLog[]
  routes           Route[]
  searchPreference UserSearchPreference?
  parkAlerts       ParkAlert[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

enum UserRole {
  USER
  ADMIN
  OPERATOR
}

// Park Models
model Park {
  id            String     @id @default(cuid())
  name          String
  slug          String     @unique
  latitude      Float?
  longitude     Float?
  website       String?
  phone         String?
  campingWebsite String?
  campingPhone   String?
  // Pricing fields
  isFree              Boolean?
  dayPassUSD          Float?
  vehicleEntryFeeUSD  Float?
  riderFeeUSD         Float?
  membershipFeeUSD    Float?
  milesOfTrails Int?
  acres         Int?
  notes         String?    @db.Text
  status        ParkStatus @default(PENDING)

  // New operational fields
  datesOpen              String?
  contactEmail           String?
  ownership              Ownership?
  permitRequired         Boolean?
  permitType             String?
  membershipRequired     Boolean?
  maxVehicleWidthInches  Int?
  flagsRequired          Boolean?
  sparkArrestorRequired  Boolean?
  helmetsRequired        Boolean?
  noiseLimitDBA          Int?

  // Map hero (auto-generated thumbnail for parks without user photos).
  // Populated by src/lib/map-hero/generate.ts on creation / coord change;
  // card falls back to live Mapbox if this is null. OP-90.
  mapHeroUrl          String?
  mapHeroGeneratedAt  DateTime?

  // Operator-selected hero image for their park card.
  // - heroSource AUTO (default): first APPROVED photo, falls back to map hero.
  // - heroSource PHOTO: use heroPhotoId (must be an APPROVED photo on this park).
  // - heroSource MAP: force use of map hero (mapHeroUrl or live ParkMapHero).
  heroPhotoId String?    @unique
  heroPhoto   ParkPhoto? @relation("ParkHeroPhoto", fields: [heroPhotoId], references: [id], onDelete: SetNull)
  heroSource  HeroSource @default(AUTO)

  // Aggregated review data
  averageRating            Float?
  averageDifficulty        Float?
  averageTerrain           Float?
  averageFacilities        Float?
  reviewCount              Int                   @default(0)
  averageRecommendedStay   RecommendedDuration?

  submittedBy   User?   @relation("SubmittedParks", fields: [submitterId], references: [id])
  submitterId   String?
  submitterName String? // For anonymous submissions

  terrain      ParkTerrain[]
  amenities    ParkAmenity[]
  camping      ParkCamping[]
  vehicleTypes ParkVehicleType[]
  favorites        UserFavorite[]
  photos           ParkPhoto[]
  reviews          ParkReview[]
  trailConditions  TrailCondition[]
  address          Address?
  operator         Operator?        @relation(fields: [operatorId], references: [id], onDelete: SetNull)
  operatorId       String?
  // Per-park override of the operator org name displayed on the park detail page
  operatorDisplayName String?
  parkClaims       ParkClaim[]
  editLogs         ParkEditLog[]
  parkAlerts       ParkAlert[]

  // AI Research fields
  dataSources          DataSource[]
  fieldExtractions     FieldExtraction[]
  researchSessions     ResearchSession[]
  dataCompletenessScore  Float?
  lastResearchedAt       DateTime?
  researchPriority       Int              @default(50)
  researchStatus         ResearchStatus   @default(NEEDS_RESEARCH)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([averageRating])
  @@index([researchStatus])
  @@index([researchPriority])
}

enum ParkStatus {
  PENDING
  APPROVED
  REJECTED
  DRAFT
}

// Junction tables for many-to-many relationships
model ParkTerrain {
  id      String  @id @default(cuid())
  parkId  String
  terrain Terrain

  park Park @relation(fields: [parkId], references: [id], onDelete: Cascade)

  @@unique([parkId, terrain])
}

model ParkAmenity {
  id      String  @id @default(cuid())
  parkId  String
  amenity Amenity

  park Park @relation(fields: [parkId], references: [id], onDelete: Cascade)

  @@unique([parkId, amenity])
}

model ParkCamping {
  id      String  @id @default(cuid())
  parkId  String
  camping Camping

  park Park @relation(fields: [parkId], references: [id], onDelete: Cascade)

  @@unique([parkId, camping])
}

model ParkVehicleType {
  id          String      @id @default(cuid())
  parkId      String
  vehicleType VehicleType

  park Park @relation(fields: [parkId], references: [id], onDelete: Cascade)

  @@unique([parkId, vehicleType])
}

// Enums matching your existing types
enum Terrain {
  sand
  rocks
  mud
  trails
  hills
  motocrossTrack
}

enum Amenity {
  restrooms
  showers
  food
  fuel
  repair
  boatRamp
  loadingRamp
  picnicTable
  shelter
  grill
  playground
  wifi
  fishing
  airStation
  trailMaps
  rentals
  training
  firstAid
  store
}

enum Camping {
  tent
  rv30A
  rv50A
  fullHookup
  cabin
  groupSite
  backcountry
}

enum VehicleType {
  motorcycle
  atv
  sxs
  fullSize
}

enum Ownership {
  private
  public
  mixed
  unknown
}

// ── AI Data Context Engine Enums ────────────────────────────────────────────

enum ResearchStatus {
  NEEDS_RESEARCH
  IN_PROGRESS
  RESEARCHED
  MAINTENANCE
}

enum DataSourceType {
  website
  pdf
  facebook
  governmentPage
  reviewSite
  campingDirectory
  other
}

enum DataSourceOrigin {
  OPERATOR_PROVIDED
  AI_DISCOVERED
  ADMIN_ADDED
  USER_SUBMITTED
}

enum CrawlStatus {
  PENDING
  SUCCESS
  FAILED
  ROBOTS_BLOCKED
  SKIPPED
  WRONG_PARK
}

enum FieldConfidence {
  OPERATOR_CONFIRMED
  HUMAN_VERIFIED
  AI_EXTRACTED
  USER_SUBMITTED
  AI_INFERRED
  NOT_FOUND
}

enum FieldExtractionStatus {
  PENDING_REVIEW
  APPROVED
  REJECTED
  SUPERSEDED
  CONFLICT
}

enum ResearchTrigger {
  SCHEDULED_CRON
  ADMIN_MANUAL
  OPERATOR_SOURCES
  NEW_PARK_SEEDED
  SOURCE_CHANGED
}

enum ResearchSessionStatus {
  IN_PROGRESS
  COMPLETED
  FAILED
  PARTIAL
}

// Address Model (one-to-one with Park)
model Address {
  id             String  @id @default(cuid())
  parkId         String  @unique
  streetAddress  String?
  streetAddress2 String?
  city           String?
  state          String  // Required for state-based filtering
  zipCode        String?
  county         String?
  latitude       Float?
  longitude      Float?

  park Park @relation(fields: [parkId], references: [id], onDelete: Cascade)

  @@index([state])
}

// User Favorites
model UserFavorite {
  id     String @id @default(cuid())
  userId String
  parkId String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  park Park @relation(fields: [parkId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([userId, parkId])
  @@index([userId])
}

// Park Photos
model ParkPhoto {
  id      String      @id @default(cuid())
  parkId  String
  userId  String?
  url     String
  caption String?     @db.Text
  status  PhotoStatus @default(PENDING)

  park       Park  @relation(fields: [parkId], references: [id], onDelete: Cascade)
  user       User? @relation(fields: [userId], references: [id], onDelete: SetNull)
  heroForPark Park? @relation("ParkHeroPhoto")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([url])
  @@index([parkId])
  @@index([userId])
  @@index([status])
}

enum HeroSource {
  AUTO
  PHOTO
  MAP
}

enum PhotoStatus {
  PENDING
  APPROVED
  REJECTED
}

// Review System
enum ReviewStatus {
  PENDING
  APPROVED
  HIDDEN
}

enum VisitCondition {
  dry
  muddy
  snow
  wet
  mixed
}

enum RecommendedDuration {
  quickRide
  halfDay
  fullDay
  overnight
}

model ParkReview {
  id                  String              @id @default(cuid())
  parkId              String
  userId              String

  // Ratings (1-5)
  overallRating       Int
  terrainRating       Int
  facilitiesRating    Int
  difficultyRating    Int

  // Content
  title               String?
  body                String              @db.Text
  visitDate           DateTime?

  // Optional fields
  vehicleType         VehicleType?
  visitCondition      VisitCondition?
  recommendedDuration RecommendedDuration?
  recommendedFor      String?

  // Status
  status              ReviewStatus        @default(PENDING)

  // Relations
  park                Park                @relation(fields: [parkId], references: [id], onDelete: Cascade)
  user                User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  helpfulVotes        ReviewHelpfulVote[]

  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  @@unique([userId, parkId])
  @@index([parkId])
  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

// Trail Conditions
enum TrailConditionStatus {
  OPEN
  CLOSED
  CAUTION
  MUDDY
  WET
  SNOW
}

enum ConditionReportStatus {
  PUBLISHED
  PENDING_REVIEW
}

model TrailCondition {
  id        String                @id @default(cuid())
  parkId    String
  userId    String
  status    TrailConditionStatus
  note      String?               @db.Text
  reportStatus   ConditionReportStatus @default(PUBLISHED)
  isOperatorPost Boolean               @default(false)
  pinnedUntil    DateTime?

  park      Park                  @relation(fields: [parkId], references: [id], onDelete: Cascade)
  user      User                  @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime              @default(now())
  updatedAt DateTime              @updatedAt

  @@index([parkId])
  @@index([userId])
  @@index([reportStatus])
  @@index([createdAt])
}

model ReviewHelpfulVote {
  id        String   @id @default(cuid())
  reviewId  String
  userId    String

  review    ParkReview @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([userId, reviewId])
  @@index([reviewId])
}

// ── Phase 2: Operator Identity & Multi-tenancy ──────────────────────────────

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  UNPAID
}

enum SubscriptionTier {
  STANDARD
  PREMIUM
}

enum ClaimStatus {
  PENDING
  APPROVED
  REJECTED
}

// Represents a park management business / operator account
model Operator {
  id                String             @id @default(cuid())
  name              String
  email             String             @unique
  phone             String?
  website           String?

  // Stripe billing fields
  stripeCustomerId       String?        @unique
  stripeSubscriptionId   String?        @unique
  subscriptionStatus     SubscriptionStatus @default(TRIALING)
  subscriptionTier       SubscriptionTier   @default(STANDARD)
  trialEndsAt            DateTime?
  subscriptionCurrentPeriodEnd DateTime?

  users  OperatorUser[]
  parks  Park[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([stripeCustomerId])
  @@index([subscriptionStatus])
}

// Junction: which users belong to which operator account (supports multi-user operator accounts)
model OperatorUser {
  id         String   @id @default(cuid())
  operatorId String
  userId     String
  role       String   @default("OWNER") // OWNER | MEMBER

  operator   Operator @relation(fields: [operatorId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt  DateTime @default(now())

  @@unique([operatorId, userId])
  @@index([userId])
}

// Park claim request — consumer requests to become operator of a park
model ParkClaim {
  id         String      @id @default(cuid())
  parkId     String
  userId     String
  status     ClaimStatus @default(PENDING)

  // Contact info provided by claimant
  claimantName    String
  claimantEmail   String
  claimantPhone   String?
  businessName    String?
  message         String?  @db.Text

  // Admin review
  reviewedAt      DateTime?
  reviewedBy      String?   // admin user id
  reviewNotes     String?   @db.Text

  park       Park        @relation(fields: [parkId], references: [id], onDelete: Cascade)
  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  @@unique([parkId, userId])
  @@index([status])
  @@index([parkId])
  @@index([userId])
}

// Audit log for operator edits to park listings
model ParkEditLog {
  id        String   @id @default(cuid())
  parkId    String
  userId    String
  // JSON snapshot of changed fields: { fieldName: { from: oldVal, to: newVal } }
  changes   String   @db.Text

  park      Park     @relation(fields: [parkId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([parkId])
  @@index([userId])
  @@index([createdAt])
}

// Saved Filters panel default — one row per user.
// Persists a user's preferred park-search Filters panel state so it can be
// auto-applied on their next visit and restored on demand.
//
// The `filters` Json blob holds the full Filters panel state shape (state,
// vehicle types, terrain, amenities, camping, rating, sliders, etc.).
// Schema is validated server-side on upsert via Zod (userSearchPreferenceSchema).
model UserSearchPreference {
  id        String   @id @default(cuid())
  userId    String   @unique
  filters   Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// Route Builder / Trip Planner
model Route {
  id                   String    @id @default(cuid())
  userId               String
  title                String
  description          String?
  shareToken           String    @unique @default(cuid())
  isPublic             Boolean   @default(false)
  waypoints            Json      // RouteWaypoint[] stored as JSON
  routeGeometry        Json?     // GeoJSON LineString from Mapbox Directions API
  totalDistanceMi      Float?
  estimatedDurationMin Int?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id])
}

// ── AI Data Context Engine ──────────────────────────────────────────────────

model DataSource {
  id            String           @id @default(cuid())
  parkId        String
  url           String
  type          DataSourceType   @default(website)
  origin        DataSourceOrigin @default(AI_DISCOVERED)
  title         String?
  description   String?
  reliability   Int              @default(50)
  isOfficial    Boolean          @default(false)

  lastCrawledAt    DateTime?
  lastContentHash  String?
  contentChanged   Boolean       @default(false)
  crawlStatus      CrawlStatus   @default(PENDING)
  crawlError       String?       @db.Text
  robotsOverride   Boolean       @default(false)
  approveCount     Int           @default(0)
  rejectCount      Int           @default(0)

  park              Park                    @relation(fields: [parkId], references: [id], onDelete: Cascade)
  fieldExtractions  FieldExtraction[]
  sessionSources    ResearchSessionSource[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([parkId, url])
  @@index([parkId])
  @@index([crawlStatus])
  @@index([lastCrawledAt])
}

model FieldExtraction {
  id              String                @id @default(cuid())
  parkId          String
  fieldName       String
  extractedValue  String?               @db.Text
  confidence      FieldConfidence       @default(AI_EXTRACTED)
  confidenceScore Float?
  status          FieldExtractionStatus @default(PENDING_REVIEW)
  sourcesChecked  Int                   @default(0)

  dataSourceId String?
  sessionId    String?
  verifiedAt   DateTime?
  verifiedBy   String?

  park       Park             @relation(fields: [parkId], references: [id], onDelete: Cascade)
  dataSource DataSource?      @relation(fields: [dataSourceId], references: [id], onDelete: SetNull)
  session    ResearchSession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([parkId, fieldName])
  @@index([status])
  @@index([parkId, fieldName, status])
}

model ResearchSession {
  id               String                 @id @default(cuid())
  parkId           String
  trigger          ResearchTrigger
  status           ResearchSessionStatus  @default(IN_PROGRESS)
  fieldsExtracted  Int                    @default(0)
  fieldsApplied    Int                    @default(0)
  sourcesFound     Int                    @default(0)
  errorMessage     String?                @db.Text
  summary          String?                @db.Text
  inputTokens      Int                    @default(0)
  outputTokens     Int                    @default(0)
  estimatedCostUSD Float                  @default(0)
  startedAt        DateTime               @default(now())
  completedAt      DateTime?

  park             Park                    @relation(fields: [parkId], references: [id], onDelete: Cascade)
  fieldExtractions FieldExtraction[]
  sessionSources   ResearchSessionSource[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([parkId])
  @@index([status])
  @@index([createdAt])
}

model ResearchSessionSource {
  id           String @id @default(cuid())
  sessionId    String
  dataSourceId String

  session    ResearchSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  dataSource DataSource      @relation(fields: [dataSourceId], references: [id], onDelete: Cascade)

  @@unique([sessionId, dataSourceId])
}

// ── Domain Reliability (OP-78) ────────────────────────────────────────────

model DomainReliability {
  id                 String   @id @default(cuid())
  domainPattern      String   @unique  // e.g. "riderplanet-usa.com", ".gov"
  defaultReliability Int      @default(50)
  isBlocked          Boolean  @default(false)
  notes              String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ── Park Discovery (OP-85) ────────────────────────────────────────────────

enum ParkCandidateStatus {
  PENDING
  ACCEPTED
  REJECTED
}

model ParkCandidate {
  id              String               @id @default(cuid())
  name            String
  state           String
  city            String?
  estimatedLat    Float?
  estimatedLng    Float?
  sourceUrl       String?
  status          ParkCandidateStatus  @default(PENDING)
  rejectedReason  String?
  seededParkId    String?              // Set when ACCEPTED → Park created

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([name, state])
  @@index([status])
  @@index([state])
}

// ── Park Alerts ────────────────────────────────────────────────────────────
// Operator-posted alerts (closures, events, weather warnings) that render as
// dismissible banners at the top of the park detail page. Distinct from
// TrailCondition — alerts are time-bounded announcements, not status updates.

enum ParkAlertSeverity {
  INFO
  WARNING
  DANGER
  SUCCESS
}

model ParkAlert {
  id        String            @id @default(cuid())
  parkId    String
  userId    String            // operator user who posted
  title     String
  body      String?           @db.Text
  severity  ParkAlertSeverity @default(INFO)
  startsAt  DateTime?         // null = active immediately
  expiresAt DateTime?         // null = indefinite
  isActive  Boolean           @default(true)

  park Park @relation(fields: [parkId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([parkId, isActive])
  @@index([expiresAt])
}
